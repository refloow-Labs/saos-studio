{
  "name": "core-service-crm",
  "version": "1.0.0",
  "description": "CRM + monitoring + scraper for the SAOS 3D website rebuild service",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && nodemon src/index.js",
    "dev:client": "cd client && vite",
    "build": "cd client && vite build",
    "start": "cd server && node src/index.js",
    "db:seed": "cd server && node src/seed.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "puppeteer": "^24.6.0",
    "cheerio": "^1.0.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.0",
    "vite": "^5.1.0",
    "@vitejs/plugin-react": "^4.2.1",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.35",
    "autoprefixer": "^10.4.17",
    "typescript": "^5.3.3",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "lucide-react": "^0.344.0",
    "framer-motion": "^11.0.0"
  }
}
