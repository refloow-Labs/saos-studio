# SAOS Autonomous Agent Configuration

# ============================================
# LEADS DATA
# ============================================
LEADS_CSV_PATH=../crm/leads-no-website.json
# Note: This will be updated to use JSON from CRM instead of CSV

# ============================================
# OPENROUTER API (Website Generation)
# ============================================
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=deepseek/deepseek-chat
OPENROUTER_SITE_URL=https://saosstudio.com
OPENROUTER_SITE_NAME=SAOS Studio

# ============================================
# NETLIFY DEPLOYMENT
# ============================================
NETLIFY_ACCESS_TOKEN=your_netlify_token_here

# ============================================
# GMAIL API (Email Sending)
# ============================================
GMAIL_CLIENT_ID=your_gmail_client_id_here
GMAIL_CLIENT_SECRET=your_gmail_client_secret_here
GMAIL_REFRESH_TOKEN=your_gmail_refresh_token_here

# ============================================
# SENDER INFORMATION
# ============================================
SENDER_NAME=Giannis Tambakis
SENDER_EMAIL=giannis@saosstudio.com
SENDER_PHONE=+30 XXX XXX XXXX

# ============================================
# AGENT CONFIGURATION
# ============================================
DAILY_WEBSITE_LIMIT=50
WEBSITES_PER_BATCH=10

# ============================================
# CRM INTEGRATION
# ============================================
CRM_DATA_PATH=../crm/data.js
CRM_PORT=8080

# ============================================
# CLAUDE CODE AGENT (Website Designer)
# ============================================
# The autonomous agent will spawn independent Claude Code sessions
# for world-class UI/UX website design
DESIGNER_AGENT_ENABLED=true
DESIGNER_AGENT_SKILL=ui-ux-pro-max
